rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users rules
    match /users/{userId} {
      allow read, write: if true; // Permissive for initial onboarding/impersonation and auth handshake
    }

    // Businesses rules
    match /businesses/{businessId} {
      allow read: if true; // Public reviews page needs to read business profile
      allow write: if true; // Allow initial business seeding on registration
    }

    // QR Codes rules
    match /qrcodes/{qrId} {
      allow read: if true; // Public reviews page needs to check QR codes
      allow write: if true;
    }

    // Reviews rules
    match /reviews/{reviewId} {
      allow read: if true; // Anyone can read reviews
      allow create: if true; // Customers submit reviews without auth
      allow update, delete: if true;
    }

    // Payments rules
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Test rules (prevents connection test permission errors on startup)
    match /test/{docId} {
      allow read, write: if true;
    }

    // Team, billing, activity logs, notifications
    match /team/{memberId} {
      allow read, write: if true;
    }
    match /activity_logs/{logId} {
      allow read, write: if true;
    }
    match /notifications/{notifId} {
      allow read, write: if true;
    }
    match /billing/{invoiceId} {
      allow read, write: if true;
    }
  }
}
